rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read their own data or admin can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }

    // Only admin can manage outlets
    match /outlets/{outletId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Outlet users can only access their own outlet's stock & transactions
    match /outlet_stock/{docId} {
      allow read, write: if request.auth != null && 
        (isAdmin() || resource.data.outletId == getUserOutlet());
    }

    match /stock_transactions/{docId} {
      allow read, write: if request.auth != null && 
        (isAdmin() || resource.data.outletId == getUserOutlet());
    }

    // Helper functions
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function getUserOutlet() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.outletId;
    }
  }
}
